# ─────────────────────────────────────────────────────────────
# Mini Jira — variables de entorno (template)
# Copia las secciones relevantes a:
#   - backend/.env   (todo lo que NO empieza con VITE_)
#   - frontend/.env  (solo VITE_*)
# Nunca commitear los .env reales — ya están en .gitignore.
# ─────────────────────────────────────────────────────────────

# ── SQL Server ──
# En el laptop actual reutilizamos el container existente `SQLServer2022` (puerto 1433).
# Usa el mismo sa-password con el que creaste ese container.
# Sólo se requiere para el fallback greenfield (docker-compose.yml en raíz).
MSSQL_SA_PASSWORD=replace-with-the-password-of-your-existing-SQLServer2022-container

# ── Backend ──
NODE_ENV=development
# Puerto 3030 — :3000 está ocupado por admosa_grafana en este entorno.
PORT=3030
# Si SQL Server corre en un container de Docker dentro de WSL (sin Docker Desktop),
# `localhost` desde Windows no llega al container — usa la IP WSL2 en su lugar
# (`wsl hostname -I` la imprime). Esa IP puede cambiar entre reinicios.
DATABASE_URL="sqlserver://localhost:1433;database=minijira;user=sa;password=replace-with-actual-password;encrypt=true;trustServerCertificate=true"

# Auth
JWT_ACCESS_SECRET=change-me-in-prod-please-use-32-bytes-min
JWT_REFRESH_SECRET=change-me-too-and-rotate-on-compromise
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d
BCRYPT_COST=12

# Pessimistic lock TTL (configurable per PRD §2.5)
LOCK_TIMEOUT_MINUTES=15

# Email (provider: resend | smtp)
EMAIL_PROVIDER=resend
EMAIL_FROM="Mini Jira <no-reply@example.com>"
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# CORS — origen del frontend en dev
CORS_ORIGIN=http://localhost:5173

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:3030/api/v1
