# Build artefactos y deps
node_modules
dist
.tsbuildinfo
*.tsbuildinfo

# Tests y coverage
coverage
**/*.test.ts
src/test

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Git y CI
.git
.gitignore
.github

# Logs
*.log
